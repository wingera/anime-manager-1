# 基础设置
APP_NAME=番剧自动整理管家
APP_ENV=development
APP_SECRET_KEY=请替换为至少32位随机字符串
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8031
FRONTEND_PORT=5173

# 容器内数据目录
DATA_DIR=/app/data
DATABASE_URL=sqlite:////app/data/app.db
CACHE_DIR=/app/data/cache
LOG_DIR=/app/data/logs

# 容器内下载目录与媒体库目录
DOWNLOAD_DIR=/downloads
MEDIA_LIBRARY_DIR=/media
DEFAULT_IMPORT_MODE=hardlink

# 宿主机挂载目录
HOST_DOWNLOAD_DIR=./downloads
HOST_MEDIA_LIBRARY_DIR=./media

# 外部服务，网页设置保存后会覆盖这里的初始值
TMDB_API_KEY=
TMDB_LANGUAGE=zh-CN
QBITTORRENT_URL=http://qbittorrent:8080
QBITTORRENT_USERNAME=
QBITTORRENT_PASSWORD=

# 匹配阈值
AUTO_PROCESS_MATCH_SCORE=85
MANUAL_REVIEW_MATCH_SCORE=60
MIN_MAIN_VIDEO_SIZE_MB=100
